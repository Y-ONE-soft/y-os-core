// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  MASTER
  STAFF
}

model User {
  id           String        @id @default(cuid())
  username     String        @unique // 로그인 아이디
  passwordHash String // bcrypt 해시 — 평문 저장 금지
  role         UserRole
  name         String
  // 소속 그룹 — 프로젝트 그룹과 동일한 축이어야 "내 소속 프로젝트" 판정이 가능하다.
  // (구 group String? 자유 문자열은 ProjectGroup과 연결되지 않아 FK로 교체)
  groupId      String?
  group        ProjectGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  title        String? // 직책
  phone        String?
  email        String?       @unique
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  sessions     Session[]
  ownedProjects Project[]

  @@index([groupId])
}

model Session {
  id        String   @id // 불투명 랜덤 세션 토큰 (base64url 32바이트)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// ── 워크스페이스(프로젝트·보드) 도메인 ──────────────────────────────
// id는 클라이언트가 접두사 uuid(g-/p-/st-/tk-/cm-)로 생성해 보낸다 — 낙관적 업데이트 시
// 임시 id 치환이 필요 없도록. 정렬은 createdAt(동률 시 id) 기준.

model ProjectGroup {
  id        String    @id
  name      String
  createdAt DateTime  @default(now())
  projects  Project[]
  users     User[]
}

model Project {
  id        String       @id
  name      String
  color     String
  createdAt DateTime     @default(now())
  groupId   String
  group     ProjectGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  // 작업자 — 스탭이 만든 프로젝트의 소유자. 배정 도메인 도입 전까지 1인 기준.
  // 사용자가 지워져도 프로젝트는 남아야 하므로 SetNull.
  ownerId   String?
  owner     User?        @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  stages    Stage[]
  tasks     Task[]

  @@index([groupId])
  @@index([ownerId])
}

model Stage {
  id                     String         @id
  name                   String
  color                  String
  startDate              String? // YYYY-MM-DD (화면 표기 규격 그대로 — TZ 이슈 회피)
  endDate                String? // YYYY-MM-DD
  showDeadline           Boolean        @default(false)
  done                   Boolean        @default(false)
  description            String?
  requestedCollaborators String[]       @default([])
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  projectId              String
  project                Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks                  Task[]
  comments               StageComment[]

  @@index([projectId])
}

model StageComment {
  id        String   @id
  author    String
  text      String
  createdAt DateTime @default(now())
  stageId   String
  stage     Stage    @relation(fields: [stageId], references: [id], onDelete: Cascade)

  @@index([stageId])
}

model Task {
  id            String   @id
  name          String
  done          Boolean  @default(false)
  description   String?
  scheduledDate String? // YYYY-MM-DD (Stage와 동일 표기 규격 — TZ 이슈 회피). null = 일정 미정
  createdAt     DateTime @default(now())
  projectId     String? // null = 미배정 (내 작업에서 만든 직후 상태)
  project       Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stageId       String? // null = 백로그
  stage         Stage?   @relation(fields: [stageId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([stageId])
}
