// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  MASTER
  STAFF
}

model User {
  id            String        @id @default(cuid())
  username      String        @unique // 로그인 아이디
  passwordHash  String // bcrypt 해시 — 평문 저장 금지
  role          UserRole
  name          String
  // 소속 그룹 — 프로젝트 그룹과 동일한 축이어야 "내 소속 프로젝트" 판정이 가능하다.
  // (구 group String? 자유 문자열은 ProjectGroup과 연결되지 않아 FK로 교체)
  groupId       String?
  group         ProjectGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  title         String? // 직책
  phone         String?
  email         String?       @unique
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  sessions      Session[]
  ownedProjects Project[]
  assignedTasks Task[]
  stagePresets  StagePreset[]

  sentRequests     Request[] @relation("SentRequests")
  receivedRequests Request[] @relation("ReceivedRequests")

  @@index([groupId])
}

model Session {
  id        String   @id // 불투명 랜덤 세션 토큰 (base64url 32바이트)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// ── 워크스페이스(프로젝트·보드) 도메인 ──────────────────────────────
// id는 클라이언트가 접두사 uuid(g-/p-/st-/tk-/cm-)로 생성해 보낸다 — 낙관적 업데이트 시
// 임시 id 치환이 필요 없도록. 정렬은 createdAt(동률 시 id) 기준.

model ProjectGroup {
  id        String    @id
  name      String
  createdAt DateTime  @default(now())
  projects  Project[]
  users     User[]
}

model Project {
  id        String       @id
  name      String
  color     String
  // 계정마다 자동 생성되는 개인 기본 프로젝트("{name}의 공통 작업") 마커.
  // 사용자당 isDefault=true 프로젝트는 하나 — 서버가 없으면 만들어 보장한다.
  isDefault Boolean      @default(false)
  // 사이드바 표시 순서 — 그룹(스탭은 소유 목록) 안에서 낮을수록 위. 드래그 재정렬 시
  // 서버가 그 그룹을 0..N-1로 다시 매긴다(같은 값이면 createdAt·id로 안정 정렬).
  // Stage.order와 달리 유니크 제약은 두지 않아 재배치 시 임시 충돌 회피가 필요 없다.
  order     Int          @default(0)
  createdAt DateTime     @default(now())
  groupId   String
  group     ProjectGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  // 작업자 — 스탭이 만든 프로젝트의 소유자. 배정 도메인 도입 전까지 1인 기준.
  // 사용자가 지워져도 프로젝트는 남아야 하므로 SetNull.
  ownerId   String?
  owner     User?        @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  stages    Stage[]
  tasks     Task[]

  @@index([groupId])
  @@index([ownerId])
}

model Stage {
  id                     String         @id
  name                   String
  color                  String
  // 프로젝트 안에서의 표시 순서 = 화면에 보이는 단계 번호. 프로젝트마다 1부터
  // 빈 번호 없이 이어진다 (생성 시 맨 뒤, 삭제·재정렬 시 서비스가 다시 매긴다).
  // createdAt 기반 정렬은 한꺼번에 만든 단계끼리 순서가 흔들려 명시 필드로 뒀다.
  order                  Int
  startDate              String? // YYYY-MM-DD (화면 표기 규격 그대로 — TZ 이슈 회피)
  endDate                String? // YYYY-MM-DD
  showDeadline           Boolean        @default(false)
  done                   Boolean        @default(false)
  description            String?
  requestedCollaborators String[]       @default([])
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  projectId              String
  project                Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks                  Task[]
  comments               StageComment[]
  requests               Request[]

  // 같은 프로젝트 안에서 번호가 겹칠 수 없다 — 중복은 DB가 막는다
  @@unique([projectId, order])
  @@index([projectId])
}

model StageComment {
  id        String   @id
  author    String
  text      String
  createdAt DateTime @default(now())
  stageId   String
  stage     Stage    @relation(fields: [stageId], references: [id], onDelete: Cascade)

  @@index([stageId])
}

model Task {
  id            String   @id
  name          String
  done          Boolean  @default(false)
  description   String?
  scheduledDate String? // YYYY-MM-DD (Stage와 동일 표기 규격 — TZ 이슈 회피). null = 일정 미정
  // HH:mm — 예정 시각. 일 뷰 시간대 그리드가 쓴다. 날짜와 같은 문자열 규격(로컬 시각,
  // TZ 이슈 회피). null = 시각 미정(하루 종일). scheduledDate 없이 시각만 있을 수는 없다.
  scheduledTime String? // HH:mm
  // 마감일 = 처음 잡은 목표일. scheduledDate를 지정/변경할 때 함께 세팅된다(재계획).
  // 미완료 할일은 하루가 지나면 scheduledDate가 오늘로 이월되지만 deadline은 고정이라,
  // 둘의 차이가 "며칠 미뤄졌는가"가 된다. null = 일정을 잡은 적 없음.
  deadline      String? // YYYY-MM-DD
  // 완료 체크 시 서버가 기록하는 날짜. 체크를 풀면 null로 되돌린다.
  // scheduledDate와 같은 YYYY-MM-DD 문자열 규격 (DateTime이 아님 — 화면이 날짜만 쓴다)
  completedDate String?
  // 컨테이너(단계·백로그·미배정) 안에서의 표시 순서 — 낮을수록 위. 드래그 재정렬 시
  // 서버가 그 컨테이너를 0..N-1로 다시 매긴다. 컨테이너를 옮기면 대상 말단으로 간다.
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  projectId     String? // null = 미배정 (내 할일에서 만든 직후 상태)
  project       Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stageId       String? // null = 백로그
  stage         Stage?   @relation(fields: [stageId], references: [id], onDelete: Cascade)
  // 담당자 — null = 미배정. 사용자가 지워져도 할일은 남아야 하므로 SetNull
  // (Project.owner와 같은 규칙).
  assigneeId    String?
  assignee      User?    @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  requests      Request[]

  @@index([projectId])
  @@index([stageId])
  @@index([assigneeId])
}

// ── 요청(알림) ────────────────────────────────────────────────
// 내 할일의 "요청 알림"에 뜨는 사람 간 요청.
// 두 종류뿐이다 — 공동 작업자로 지정하는 할일 요청, 막힌 일을 봐달라는 도움 요청.

enum RequestKind {
  ASSIGN // 할일 요청 — 공동 작업자 지정
  HELP // 도움 요청
}

enum RequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELED // 보낸 사람이 회수
}

model Request {
  id          String        @id // "rq-<uuid>" — 클라이언트가 생성해 보낸다(낙관적 업데이트)
  kind        RequestKind
  status      RequestStatus @default(PENDING)
  message     String? // 요청 사유 (선택)
  createdAt   DateTime      @default(now())
  respondedAt DateTime? // 수락·거절·취소 시각

  fromUserId String
  fromUser   User   @relation("SentRequests", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUserId   String
  toUser     User   @relation("ReceivedRequests", fields: [toUserId], references: [id], onDelete: Cascade)

  // 요청 대상 — 할일 또는 단계 중 하나만 채워진다.
  // 대상이 지워지면 요청도 의미가 없으므로 Cascade.
  taskId  String?
  task    Task?   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  stageId String?
  stage   Stage?  @relation(fields: [stageId], references: [id], onDelete: Cascade)

  @@index([toUserId, status])
  @@index([fromUserId, status])
  @@index([taskId])
  @@index([stageId])
}

// ── 단계 프리셋 ──────────────────────────────────────────────
// 프로젝트의 단계·할일 구성을 통째로 담는 개인용 템플릿.
// 실제 날짜 대신 기준일(저장 시점 가장 이른 단계 시작일) 기준 상대 오프셋을 담아,
// 적용할 때 지정한 시작일부터 같은 간격·길이로 재현한다.
// 완료 여부·설명·댓글 등 인스턴스 데이터는 담지 않는다.

model StagePreset {
  id        String             @id // "ps-<uuid>"
  ownerId   String // 개인용 — 만든 사람만 조회·수정할 수 있다
  owner     User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  stages    StagePresetStage[]

  // 이름 중복은 사용자 안에서만 막는다 (덮어쓰기 대상이 모호해지지 않도록)
  @@unique([ownerId, name])
  @@index([ownerId])
}

model StagePresetStage {
  id           String            @id // "pss-<uuid>"
  presetId     String
  preset       StagePreset       @relation(fields: [presetId], references: [id], onDelete: Cascade)
  name         String
  color        String
  order        Int
  // 기준일로부터 며칠 뒤 시작하는지. null = 날짜가 없던 단계
  offsetDays   Int?
  // 기간(일). null = 종료일이 없던 진행형 막대
  durationDays Int?
  tasks        StagePresetTask[]

  @@index([presetId])
}

model StagePresetTask {
  id         String           @id // "pst-<uuid>"
  stageId    String
  stage      StagePresetStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  name       String
  order      Int
  // 예정일 오프셋. null = 일정 미정이던 할일
  offsetDays Int?

  @@index([stageId])
}
